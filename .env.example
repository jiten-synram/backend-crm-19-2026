# ================================================================
# YOGVEDA CRM — BACKEND ENVIRONMENT VARIABLES
# Copy this file to  .env  and fill your real values
# Never commit .env to any repository
# ================================================================

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Your domain / URLs ──────────────────────────────────────────
FRONTEND_URL=https://crm.yourdomain.com
API_BASE_URL=https://crm.yourdomain.com/api

# ── MySQL (cPanel) ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=yogveda_crm
DB_USER=cpanel_username_yogveda
DB_PASS=your_mysql_password_here

# ── JWT ──────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX
JWT_EXPIRES_IN=15m

# ── WhatsApp Business API ────────────────────────────────────────
# Meta Business → Apps → WhatsApp → Getting Started
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=yogveda_verify_2025

# ── Shopify ──────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
SHOPIFY_WEBHOOK_SECRET=

# ── Make.com ─────────────────────────────────────────────────────
# No key needed — Make.com posts to your webhook URL
# Register this URL in Make.com:
# https://crm.yourdomain.com/api/webhooks/meta-leads
