{
  "name": "yogveda-crm-backend",
  "version": "1.0.0",
  "description": "Yogveda Healthcare CRM — Node.js + MySQL Backend",
  "main": "src/app.js",
  "scripts": {
    "start":      "node src/app.js",
    "dev":        "nodemon src/app.js",
    "seed":       "node src/scripts/seed.js",
    "pm2:start":  "pm2 start src/app.js --name yogveda-crm --watch false --max-memory-restart 400M",
    "pm2:stop":   "pm2 stop yogveda-crm",
    "pm2:restart":"pm2 restart yogveda-crm",
    "pm2:logs":   "pm2 logs yogveda-crm"
  },
  "dependencies": {
    "axios":              "^1.6.0",
    "bcryptjs":           "^2.4.3",
    "compression":        "^1.7.4",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "exceljs":            "^4.3.0",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":             "^7.1.0",
    "json2csv":           "^6.0.0-alpha.2",
    "jsonwebtoken":       "^9.0.2",
    "morgan":             "^1.10.0",
    "mysql2":             "^3.6.5",
    "node-cron":          "^3.0.3",
    "pdfkit":             "^0.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
